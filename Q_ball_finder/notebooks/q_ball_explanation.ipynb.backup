      "Negative-mode growth rate γ = 0.129338\n"
     ]
    }
   ],
   "source": [
    "unstable_mode = compute_unstable_mode(qcloud_profile)\n",
    "print(f\"Negative-mode growth rate γ = {unstable_mode.gamma:.6f}\")\n"
   ]
  },
