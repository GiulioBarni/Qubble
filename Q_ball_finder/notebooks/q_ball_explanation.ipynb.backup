   "source": [
    "# Diagnostic slices of the negative-mode ansatz density\n",
    "rs = grid.r\n",
    "taus = grid.tau\n",
    "\n",
    "# Pick representative Euclidean times (near the cloud centre and towards tau=0)\n",
    "tau_targets = [grid.tau.min(), grid.tau.min() / 2.0, -beta_ansatz / 4.0, 0.0]\n",
    "tau_indices = [int(np.argmin(np.abs(taus - tau_val))) for tau_val in tau_targets]\n",
    "\n",
    "# Pick a few radial locations (including r=0 and the outer tail)\n",
    "r_targets = [0.0, 1.0, 2.5, 5.0, 7.5]\n",
    "r_indices = [int(np.argmin(np.abs(rs - r_val))) for r_val in r_targets]\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 4.5), constrained_layout=True)\n",
    "for idx, tau_idx in enumerate(tau_indices):\n",
    "    label = rf\"$\\tau = {taus[tau_idx]:.2f}$\"\n",
    "    axes[0].plot(rs, rho_guess[:, tau_idx], lw=1.8, label=label)\n",
    "axes[0].set_xlabel(r\"$r$\")\n",
    "axes[0].set_ylabel(r\"$\\rho(r,\\tau)$\")\n",
    "axes[0].set_title(r\"Slices at fixed $\\tau$\")\n",
    "axes[0].set_xlim(0, 9)\n",
    "axes[0].grid(True, ls=\"--\", alpha=0.5)\n",
    "axes[0].legend(title=\"Euclidean time\", loc=\"best\")\n",
    "\n",
    "for idx, r_idx in enumerate(r_indices):\n",
    "    label = rf\"$r = {rs[r_idx]:.2f}$\"\n",
