# =============================================================================
# Qubble — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
venv/
env/
ENV/
.venv/
.venv

# -----------------------------------------------------------------------------
# Jupyter / notebook artefacts
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
**/.ipynb_checkpoints/
*.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# Test / type-checker / linter caches
# -----------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/

# -----------------------------------------------------------------------------
# IDE / editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS-specific
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Numerical scratch / cached data
# -----------------------------------------------------------------------------
# Binary cached solutions (regenerable from the notebooks; large datasets are
# archived externally — see the README files for the Zenodo link, when
# available).
*.npz
*.npy
*.h5
*.hdf5

# Heavy beta-scan dataset (Q-ball auxiliary pipeline). These solutions are
# expensive to recompute and are archived externally rather than tracked in
# git. See Q_ball_finder/README.md.
Q_ball_finder/data/beta_scan_solutions/

# Local scratch directories sometimes produced by the notebooks.
outputs/
scratch/
tmp/

# -----------------------------------------------------------------------------
# Temporary / log files
# -----------------------------------------------------------------------------
*.tmp
*.log
*.bak

# -----------------------------------------------------------------------------
# PDF outputs — kept tracked by default (they include the paper figures).
# Uncomment the line below to exclude all PDFs from git.
# -----------------------------------------------------------------------------
# *.pdf
