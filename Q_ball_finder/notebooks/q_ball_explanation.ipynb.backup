   "source": [
    "R, T = np.meshgrid(grid.r, grid.tau, indexing=\"xy\")\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 4.5), constrained_layout=True)\n",
    "cf0 = axes[0].pcolormesh(R, T, rho_guess.T, shading=\"auto\")\n",
    "axes[0].set_title(r\"$\\rho(r,\\tau)=\\sqrt{\\phi\\bar\\phi}$\")\n",
    "axes[0].set_xlabel(r\"$r$\")\n",
    "axes[0].set_xlim(0, 9)\n",
    "axes[0].set_ylabel(r\"$\\tau$\")\n",
    "fig.colorbar(cf0, ax=axes[0])\n",
    "\n",
    "# Additional diagnostic: sqrt(y_cl * ybar_cl)\n",
    "y_guess, ybar_guess = ansatz.y, ansatz.ybar\n",
    "rho_y = np.sqrt(np.maximum((y_guess * ybar_guess).real, 0.0))\n",
    "\n",
    "cf1 = axes[1].pcolormesh(R, T, rho_y.T, shading=\"auto\")\n",
    "axes[1].set_title(r\"$\\sqrt{y_{\\rm cl}\\,\\bar y_{\\rm cl}}$\")\n",
    "axes[1].set_xlabel(r\"$r$\")\n",
    "axes[1].set_xlim(0, 9)\n",
    "axes[1].set_ylabel(r\"$\\tau$\")\n",
    "fig.colorbar(cf1, ax=axes[1])\n",
    "plt.show()\n"
   ]
