   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy.special import expit  # σ(x) = 1 / (1 + e^{-x})\n",
    "\n",
    "# -----------------------------\n",
    "# Paper potential V(ρ) with ρ = |φ|^2, χ = |φ|\n",
    "# -----------------------------\n",
    "m, v, b = 1, 1.0, 8.0\n",
    "c = np.exp(-b) / (1.0 + np.exp(-b))  # c = e^{-b} / (1 + e^{-b})\n",
    "\n",
    "# Precalcolo utile\n",
    "logc = np.log(c)\n",
    "\n",
    "def V_rho(rho):\n",
    "    r\"\"\"\n",
    "    V(ρ) = - (m^2 v^2 / b) * log( e^{-b ρ / v^2} + c )\n",
    "\n",
    "    Implementato in forma numericamente stabile usando logaddexp:\n",
    "    log(e^z + c) = logaddexp(z, log c), con z = -b ρ / v^2.\n",
    "    \"\"\"\n",
    "    z = -b * rho / (v * v)  # può essere molto negativo o moderatamente positivo\n",
    "    return -(m*m*v*v / b) * np.logaddexp(z, logc)\n",
    "\n",
    "\n",
    "def dV_drho(rho):\n",
    "    r\"\"\"\n",
    "    ∂V/∂ρ = m^2 * e^{-b ρ / v^2} / (e^{-b ρ / v^2} + c)\n",
    "          = m^2 / (1 + c e^{b ρ / v^2})\n",
    "          = m^2 * σ( - (log c + b ρ / v^2) ), con σ la sigmoid logistica.\n",
    "    \"\"\"\n",
    "    t = (b * rho / (v * v)) + logc\n",
    "    # expit(x) = 1 / (1 + e^{-x}), quindi expit(-t) = 1 / (1 + e^{t})\n",
    "    return m*m * expit(-t)\n",
    "\n",
    "\n",
    "def V_chi(chi):\n",
    "    r\"\"\"\n",
    "    V(χ) con ρ = χ^2 / 2.\n",
    "    \"\"\"\n",
    "    rho = 0.5 * chi * chi\n",
    "    return V_rho(rho)\n",
    "\n",
    "\n",
    "def dV_dchi(chi):\n",
    "    r\"\"\"\n",
    "    ∂V/∂χ = (∂V/∂ρ) * (∂ρ/∂χ)\n",
    "          = (∂V/∂ρ) * χ, con ρ = χ^2 / 2.\n",
    "    \"\"\"\n",
    "    rho = 0.5 * chi * chi\n",
    "    return chi * dV_drho(rho)\n",
    "\n",
    "# -----------------------------\n",
    "# Q-ball effective potential at fixed ω:\n",
    "#   V_hat(χ) = V(χ) - 1/2 * ω^2 * χ^2\n",
    "# -----------------------------\n",
    "omega = 0.8765 * m\n",
    "\n",
    "def Vhat(chi):\n",
    "    return V_chi(chi) - 0.5 * (omega**2) * chi * chi\n",
    "\n",
    "# Use Vhat downstream (gradient via your existing numgrad)\n",
    "V  = lambda x: Vhat(x)\n",
    "dV = lambda x: numgrad(V, x)  # assumes numgrad is defined elsewhere\n",
    "\n",
    "# -----------------------------\n",
    "# Solve bounce (supports bounded/unbounded via flags)\n",
    "# -----------------------------\n",
    "out = solve_bounce(\n",
    "    V, dV=dV, d=3,\n",
    "    x_min=-1.0, x_max=6.0,\n",
    "    allow_unbounded=True,  # set False for bounded case\n",
    "    phi0_cap=10.0,         # user cap for unbounded bracketing\n",
    "    prefer_side='+',       # look for the barrier on the + side\n",
    "    verbose=True\n",
    ")\n",
    "\n",
    "# -----------------------------\n",
    "# Two-panel plot: potential (left) and profile (right) + charge Q\n",
    "# -----------------------------\n",
    "phi0 = out['phi0']\n",
    "true_vac_x = out['true_vac']['x'] if out.get('true_vac') is not None else None\n",
    "\n",
    "# Compute Q if not provided (valid for d=3): Q = 2 ω ∫ d^3x χ^2 = 8π ω ∫ dr r^2 χ^2\n",
    "Q = None\n",
    "try:\n",
    "    if 'Q' in out and np.isfinite(out['Q']):\n",
    "        Q = out['Q']\n",
    "    elif out.get('d', 3) == 3:\n",
    "        r   = out['r']\n",
    "        chi = out['phi']\n",
    "        fourpi = 4.0 * np.pi\n",
    "        Q = omega * fourpi * np.trapezoid(r * r * chi * chi, r)\n",
    "except Exception:\n",
    "    Q = None\n",
    "\n",
    "# Left panel x-range: [-1, 1.2 * max(phi0, true_vac_x)]\n",
    "xmax_left = 1.2 * (max(phi0, true_vac_x) if true_vac_x is not None else phi0)\n",
    "xs = np.linspace(-1.0, xmax_left, 300)\n",
    "Vs = [V(x) for x in xs]\n",
    "\n",
    "fig, ax = plt.subplots(1, 2, figsize=(11, 4.2), constrained_layout=True)\n",
    "\n",
    "# Left: V_hat(φ)\n",
    "ax[0].plot(xs, Vs, lw=2, color='C0')\n",
    "ax[0].set_xlabel(r\"$|\\phi|$\")\n",
    "ax[0].set_ylabel(r\"$\\hat V(|\\phi|)$\")\n",
    "ax[0].set_title(\"Effective potential\")\n",
    "ax[0].grid(True, ls=\"--\", alpha=0.6)\n",
    "ax[0].set_xlim(-1.0, xmax_left)\n",
    "\n",
    "# Markers: false/true vacuum, top, and φ(0) when available\n",
    "if out.get('false_vac') is not None:\n",
    "    xf, Vf = out['false_vac']['x'], out['false_vac']['V']\n",
    "    ax[0].axvline(xf, color='C1', ls='--', lw=1.5, label=\"false vacuum\")\n",
    "    ax[0].scatter([xf], [Vf], color='C1', zorder=5)\n",
    "\n",
    "if out.get('true_vac') is not None:\n",
    "    xt, Vt = out['true_vac']['x'], out['true_vac']['V']\n",
    "    ax[0].axvline(xt, color='C2', ls='--', lw=1.5, label=\"true vacuum\")\n",
    "    ax[0].scatter([xt], [Vt], color='C2', zorder=5)\n",
    "\n",
    "if out.get('top') is not None:\n",
    "    xM, VM = out['top']['x'], out['top']['V']\n",
    "    ax[0].axvline(xM, color='C3', ls=':', lw=1.5, label=\"barrier top\")\n",
    "    ax[0].scatter([xM], [VM], color='C3', marker='^', zorder=5)\n",
    "\n",
    "ax[0].axvline(phi0, color='k', ls='-.', lw=1.2, label=r\"$\\phi(0)$ (shooting)\")\n",
    "ax[0].legend(loc=\"best\", fontsize=10)\n",
    "\n",
    "# Right: χ(r)\n",
    "ax[1].plot(out['r'], out['phi']/np.sqrt(2), lw=2, color='C4')\n",
    "ax[1].set_xlabel(r\"$r$\")\n",
    "ax[1].set_ylabel(r\"$|\\phi(r)|$\")\n",
    "ax[1].axhline(0, color='k', ls='--', lw=1.2)\n",
    "ax[1].set_title(\"Bounce profile\")\n",
    "ax[1].grid(True, ls=\"--\", alpha=0.6)\n",
    "ax[1].set_ylim(-0.5, 1.1 * abs(phi0))\n",
    "\n",
    "# Suptitle with S_E and (optionally) Q\n",
    "title = rf\"Bounce ($d={out['d']}$) — $S_E \\simeq {out['SE']:.3g}$\"\n",
    "if Q is not None and np.isfinite(Q):\n",
    "    title += rf\",  $Q \\simeq {Q:.3g}$\"\n",
    "fig.suptitle(title, fontsize=13)\n",
    "\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# --- Inputs / scales (must be defined in your notebook) ---\n",
    "# m, v must exist; V_chi(chi) must be defined (paper potential)\n",
    "# numgrad(f, x) and solve_bounce(...) must also be available\n",
    "\n",
    "def compute_g2Q_from_out(out, m, v, omega):\n",
    "    \"\"\"\n",
    "    Returns dimensionless g^2 Q = 4π ω̃ ∫ d r̃ r̃^2 ϕ^2,\n",
    "    with r̃ = m r and ϕ = φ / v, ω̃ = ω / m.\n",
    "    \"\"\"\n",
    "    r_phys  = np.asarray(out['r'])\n",
    "    phi_phys= np.asarray(out['phi'])\n",
    "    r_tilde = m * r_phys\n",
    "    varphi  = phi_phys / v\n",
    "    I = np.trapezoid((r_tilde**2) * (varphi**2), r_tilde)\n",
    "    return 4.0 * np.pi * (omega/m) * I\n",
    "\n",
    "import numpy as np\n",
    "\n",
    "# Assumo che V_chi sia già definita e che m, v fissino la scala del potenziale\n",
    "V0 = V_chi(0.0)  # energia di vuoto del campo complesso: χ = 0 ⇒ ρ = 0\n",
    "\n",
    "def compute_E_from_out(out, m, v, omega, V_chi):\n",
    "    \"\"\"\n",
    "    Calcola l'energia E del Q-ball (sopra il vuoto) a partire dall'output 'out'\n",
    "    del solver di bounce, usando l'ansatz φ = χ/√2 e^{i ω t}.\n",
    "\n",
    "    Formula:\n",
    "      E = 4π ∫ dr r^2 [ 1/2 (dχ/dr)^2 + 1/2 ω^2 χ^2 + (V_chi(χ) - V_chi(0)) ].\n",
    "\n",
    "    Parametri\n",
    "    ---------\n",
    "    out   : dict\n",
    "        Output di solve_bounce, con chi(r) in out['phi'] e r in out['r'].\n",
    "        Se disponibile, out['phip'] è dχ/dr e viene usata preferenzialmente.\n",
    "    m, v  : float\n",
    "        Masse/scale del modello (non entrano esplicitamente in E, ma le\n",
    "        includiamo per consistenza con altre funzioni tipo compute_g2Q...).\n",
    "    omega : float\n",
    "        Frequenza ω del Q-ball.\n",
    "    V_chi : callable\n",
    "        Potenziale effettivo V_chi(χ).\n",
    "\n",
    "    Ritorna\n",
    "    -------\n",
    "    E : float\n",
    "        Energia totale sopra il vuoto.\n",
    "    \"\"\"\n",
    "\n",
    "    r   = np.asarray(out['r'])\n",
    "    chi = np.asarray(out['phi'])\n",
    "\n",
    "    # Derivata radiale dχ/dr\n",
    "    if 'phip' in out and out['phip'] is not None:\n",
    "        dchi_dr = np.asarray(out['phip'])\n",
    "    else:\n",
    "        # np.gradient gestisce step non uniformi; edge_order=2 per maggiore accuratezza\n",
    "        dchi_dr = np.gradient(chi, r, edge_order=2)\n",
    "        # regolarità al centro (in d=3: χ'(0) = 0)\n",
    "        dchi_dr[0] = 0.0\n",
    "\n",
    "    fourpi = 4.0 * np.pi\n",
    "\n",
    "    # Integrando: 1/2 (∂r χ)^2 + 1/2 ω^2 χ^2 + (V_chi(χ) - V_chi(0))\n",
    "    integrand = (\n",
    "        0.5 * dchi_dr * dchi_dr\n",
    "        + 0.5 * omega * omega * chi * chi\n",
    "        + (V_chi(chi) - V0)\n",
    "    )\n",
    "\n",
    "    # E = 4π ∫ dr r^2 integrand\n",
    "    E = fourpi * np.trapezoid(r * r * integrand, r)\n",
    "\n",
    "    return E\n",
    "\n",
    "\n",
    "\n",
    "def solve_qball_for_omega(omega, phi0_cap=15.0, x_min=-1.0, x_max=6.0, verbose=False):\n",
    "    \"\"\"\n",
    "    Build V_hat(χ) = V(χ) - 1/2 ω^2 χ^2 and solve for the profile\n",
    "    using your bounce solver. We use allow_unbounded=True so it brackets\n",
    "    beyond the barrier if needed.\n",
    "    \"\"\"\n",
    "    def Vhat(chi):\n",
    "        return V_chi(chi) - 0.5 * (omega**2) * chi * chi\n",
    "\n",
    "    V  = lambda x: Vhat(x)\n",
    "    dV = lambda x: numgrad(V, x)\n",
    "\n",
    "    out = solve_bounce(\n",
    "        V, dV=dV, d=3,\n",
    "        x_min=x_min, x_max=x_max,\n",
    "        allow_unbounded=True, phi0_cap=phi0_cap,\n",
    "        prefer_side='+', verbose=verbose\n",
    "    )\n",
    "    return out\n",
    "\n",
    "\n",
    "# --- Scan in ω̃ = ω/m ---\n",
    "lo, hi = 0.750, 1\n",
    "N = 120\n",
    "\n",
    "# --- Scan in ω̃ = ω/m ---\n",
    "lo, hi = 0.750, 1\n",
    "N = 60\n",
    "\n",
    "# denser sampling near √2\n",
    "wtilde_grid = hi - np.geomspace(hi - lo, 1e-4, N)\n",
    "\n",
    "g2Q_vals, Es_vals, SE_vals, wtilde_ok = [], [], [], []\n",
    "\n",
    "for wt in wtilde_grid:\n",
    "    try:\n",
    "        w = wt * m  # ω = ω̃ m\n",
    "\n",
    "        # risolvi il profilo del Q-ball\n",
    "        out = solve_qball_for_omega(\n",
    "            w,\n",
    "            phi0_cap=10.0,\n",
    "            x_min=-1.0,\n",
    "            x_max=6.0,\n",
    "            verbose=False\n",
    "        )\n",
    "\n",
    "        # g^2 Q (come prima)\n",
    "        g2Q = compute_g2Q_from_out(out, m, v, w)\n",
    "        g2Q_vals.append(g2Q)\n",
    "\n",
    "        # Energia E(ω̃) sopra il vuoto\n",
    "        E = compute_E_from_out(out, m, v, w, V_chi)\n",
    "        Es_vals.append(E)\n",
    "\n",
    "        # Azione del bounce S_E\n",
    "        SE_vals.append(out['SE'])\n",
    "\n",
    "        # salva solo i punti che convergono\n",
    "        wtilde_ok.append(wt)\n",
    "\n",
    "    except Exception as e:\n",
    "        # per debug puoi attivare questa riga:\n",
    "        # print(f\"wt = {wt:.6f} FAILED: {e}\")\n",
    "        continue\n",
    "\n",
    "wtilde_ok = np.array(wtilde_ok)\n",
    "g2Q_vals  = np.array(g2Q_vals)\n",
    "Es_vals   = np.array(Es_vals)\n",
    "SE_vals   = np.array(SE_vals)\n",
    "\n",
    "\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Prepare data\n",
    "x = wtilde_ok              # ω/m\n",
    "yQ = g2Q_vals              # g^2 Q\n",
    "yE = Es_vals               # E(ω)\n",
    "\n",
    "# Keep only finite points and sort by x (safer)\n",
    "mask = np.isfinite(x) & np.isfinite(yQ) & np.isfinite(yE)\n",
    "x, yQ, yE = x[mask], yQ[mask], yE[mask]\n",
    "\n",
    "order = np.argsort(x)\n",
    "x  = x[order]\n",
    "yQ = yQ[order]\n",
    "yE = yE[order]\n",
    "\n",
    "# Find the minimum of g^2 Q (defines ω_c and (g^2 Q)_c)\n",
    "imin = int(np.nanargmin(yQ))\n",
    "xmin, ymin = x[imin], yQ[imin]\n",
    "\n",
    "# ========= Plot 1: g^2 Q vs ω/m =========\n",
    "plt.figure(figsize=(6.2, 4.4))\n",
    "\n",
    "# Left of the minimum: solid red\n",
    "plt.plot(x[:imin+1], yQ[:imin+1], 'r-', lw=1.8, label='left branch')\n",
    "\n",
    "# Right of the minimum: dashed blue\n",
    "plt.plot(x[imin:],  yQ[imin:],  'b--', lw=1.8, label='right branch')\n",
    "\n",
    "# Mark the minimum point\n",
    "plt.plot([xmin], [ymin], 'ko', ms=6, label='minimum')\n",
    "\n",
    "# Vertical lines: at the minimum and at 1\n",
    "plt.axvline(xmin, color='gray', ls='-',  lw=1.2, label=r'$\\omega_c/m$')\n",
    "plt.axvline(1.0,  color='k',    ls='--', lw=1.2, label=r'$\\omega/m = 1$')\n",
    "\n",
    "plt.xlabel(r\"$\\omega/m$\")\n",
    "plt.ylabel(r\"$g^2 Q$\")\n",
    "plt.ylim(0, 1000)\n",
    "plt.xlim(0.77, 1.01)\n",
    "plt.grid(True, ls=\"--\", alpha=0.6)\n",
    "plt.legend(fontsize=9, loc='best')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# ========= Plot 2: E vs ω/m =========\n",
    "plt.figure(figsize=(6.2, 4.4))\n",
    "\n",
    "# stesso split a sinistra/destra del minimo in ω\n",
    "plt.plot(x[:imin+1], yE[:imin+1], 'r-', lw=1.8, label='left branch')\n",
    "plt.plot(x[imin:],  yE[imin:],  'b--', lw=1.8, label='right branch')\n",
    "\n",
    "# segna il valore a ω_c\n",
    "Ec = yE[imin]\n",
    "plt.plot([xmin], [Ec], 'ko', ms=6, label=r'$E(\\omega_c)$')\n",
    "\n",
    "plt.axvline(xmin, color='gray', ls='-',  lw=1.2, label=r'$\\omega_c/m$')\n",
    "plt.axvline(1.0,  color='k',    ls='--', lw=1.2, label=r'$\\omega/m = 1$')\n",
    "\n",
    "plt.xlabel(r\"$\\omega/m$\")\n",
    "plt.ylabel(r\"$E$\")\n",
    "plt.ylim(0,1000)\n",
    "plt.grid(True, ls=\"--\", alpha=0.6)\n",
    "plt.legend(fontsize=9, loc='best')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Fit quadratico locale sul minimo di g^2 Q (come prima)\n",
    "if 0 < imin < len(x) - 1:\n",
    "    x_fit = x[imin-1:imin+2]\n",
    "    y_fit = yQ[imin-1:imin+2]\n",
    "\n",
    "    a, b, c = np.polyfit(x_fit, y_fit, 2)\n",
    "    xmin = -b / (2 * a)\n",
    "    ymin = np.polyval([a, b, c], xmin)\n",
    "else:\n",
    "    xmin, ymin = x[imin], yQ[imin]\n",
    "\n",
    "print(\"Critical point (from g^2 Q):\")\n",
    "print(f\"  ω/m   = {xmin:.6f}\")\n",
    "print(f\"  g²Q_c = {ymin:.6f}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Partiamo dai risultati dello scan\n",
    "# wtilde_ok : ω/m per cui il solver ha trovato una soluzione\n",
    "# g2Q_vals  : g^2 Q(ω̃)\n",
    "# Es_vals   : E(ω̃) sopra il vuoto\n",
    "\n",
    "x  = wtilde_ok        # ω/m\n",
    "Q  = g2Q_vals         # qui usiamo Q = g^2 Q (coerente col paper fino a una costante)\n",
    "E  = Es_vals          # energia sopra il vuoto\n",
    "\n",
    "# Pulisci: punti finiti e Q>0 (escludi soluzioni banali Q≈0)\n",
    "mask = np.isfinite(x) & np.isfinite(Q) & np.isfinite(E) & (Q > 0)\n",
    "x, Q, E = x[mask], Q[mask], E[mask]\n",
    "\n",
    "# Ordina in ω/m (molto importante per separare i rami)\n",
    "order = np.argsort(x)\n",
    "x, Q, E = x[order], Q[order], E[order]\n",
    "\n",
    "# Trova il minimo di Q(ω̃): questo definisce Qc ed Ec\n",
    "imin = int(np.argmin(Q))\n",
    "Qc, Ec = Q[imin], E[imin]\n",
    "\n",
    "print(f\"Qc (in unità g^2Q)  = {Qc:.6g}\")\n",
    "print(f\"Ec = E(Qc)          = {Ec:.6g}\")\n",
    "print(f\"(ω/m)_c             = {x[imin]:.8f}\")\n",
    "\n",
    "# Variabili adimensionali per Fig. 4:\n",
    "# X = Q/Qc, Y = (E - Q)/E(Qc) (assumendo m=1, e usando Q=g^2Q)\n",
    "X = Q / Qc\n",
    "Y = (E - Q) / Ec\n",
    "\n",
    "# Separa i due rami in base al minimo in ω:\n",
    "# - branch \"left\": ω < ω_c\n",
    "# - branch \"right\": ω > ω_c\n",
    "X_left,  Y_left  = X[:imin+1], Y[:imin+1]\n",
    "X_right, Y_right = X[imin:],   Y[imin:]\n",
    "\n",
    "# (opzionale ma consigliato) ordina ogni ramo in X per avere curve monotone\n",
    "orderL = np.argsort(X_left)\n",
    "orderR = np.argsort(X_right)\n",
    "\n",
    "X_left,  Y_left  = X_left[orderL],  Y_left[orderL]\n",
    "X_right, Y_right = X_right[orderR], Y_right[orderR]\n",
    "\n",
    "Xs = np.nan\n",
    "s = np.sign(Y_left)\n",
    "k = np.where(s[:-1] * s[1:] < 0)[0]\n",
    "\n",
    "if k.size:\n",
    "    j = k[0]\n",
    "    x1, y1 = X_left[j],   Y_left[j]\n",
    "    x2, y2 = X_left[j+1], Y_left[j+1]\n",
    "    Xs = x1 + (0.0 - y1) * (x2 - x1) / (y2 - y1)\n",
    "    print(f\"Estimated Qs/Qc ≈ {Xs:.3f}\")\n",
    "else:\n",
    "    print(\"No zero crossing found on the Q-ball branch.\")\n",
    "\n",
    "# ==============================\n",
    "# Plot (E - Q)/E(Qc) vs Q/Qc\n",
    "# ==============================\n",
    "plt.figure(figsize=(6.4, 4.4))\n",
    "\n",
    "plt.plot(X_left,  Y_left,  'r-', lw=1.8, label='Q-cloud branch')\n",
    "plt.plot(X_right, Y_right, 'b--',  lw=1.8, label='Q-ball branch')\n",
    "\n",
    "# Punto critico Q = Qc (X=1)\n",
    "plt.scatter([1.0], [Y[imin]], s=50, facecolors='white', edgecolors='k', zorder=5, label=r'$Q = Q_c$')\n",
    "\n",
    "# Crossing di stabilità assoluta (se esiste)\n",
    "if np.isfinite(Xs):\n",
    "    plt.scatter([Xs], [0.0], s=50, facecolors='white', edgecolors='k', zorder=6,\n",
    "                label=rf'$Q_s/Q_c \\approx {Xs:.2f}$')\n",
    "\n",
    "plt.axvline(1.0, color='k', ls='--', lw=1.0)\n",
    "plt.axhline(0.0, color='k', lw=1.0)\n",
    "\n",
    "plt.xlabel(r\"$Q/Q_c$\")\n",
    "plt.ylabel(r\"$(E - Q)/E(Q_c)$\")   # con m=1 e Q ≡ g^2Q\n",
    "plt.xlim(0.9, 2.5)\n",
    "plt.ylim(-.1,.1)\n",
    "plt.grid(True, ls=\"--\", alpha=0.6)\n",
    "plt.legend(fontsize=9)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "if np.isfinite(Xs):\n",
    "    print(f\"Absolute stability roughly at Q_s/Q_c ≈ {Xs:.6f}\")\n"
   ]
  },
